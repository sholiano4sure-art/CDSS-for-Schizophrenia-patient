#Shiny Server
```{r}
server <- function(input, output, session) {
  
  # Patient Info
  output$patient_summary <- renderPrint({
    pid <- as.numeric(input$patient_id)
    info <- model_data[pid, c("Age","Gender","SymptomSeverity","TreatmentHistory","Label","Risk_Category")]
    print(info)
  })
  
  output$ehr_table <- renderDataTable({
    model_data %>% select(Age, Gender, SymptomSeverity, TreatmentHistory, Label, Risk_Category)
  })
  
  # EEG Feature Summary
  output$signal_summary <- renderPlot({
    pid <- as.numeric(input$patient_id)
    epoch_signal <- as.numeric(epochs_norm[pid, ])
    plot(epoch_signal, type = 'l', col = 'blue',
         main = paste("EEG Epoch Signal for Patient", pid),
         xlab = "Sample", ylab = "Amplitude (Normalized)")
  })
  
  output$pca_plot <- renderPlot({
    ggplot(pca_features, aes(x = PC1, y = PC2, color = Label)) +
      geom_point(size=2) +
      theme_minimal() +
      ggtitle("PCA Feature Scatterplot (PC1 vs PC2)")
  })
  
  output$feature_table <- renderDataTable({
    pid <- as.numeric(input$patient_id)
    as.data.frame(feature_matrix_norm[pid, , drop=FALSE])
  })
  
  # Forecast & Alert (Gauge)
  output$risk_gauge <- flexdashboard::renderGauge({
    pid <- as.numeric(input$patient_id)
    risk_prob <- model_data$RF_Prob[pid]
    flexdashboard::gauge(
      value = risk_prob * 100,
      min = 0, max = 100,
      sectors = flexdashboard::gaugeSectors(
        success = c(0,50),
        warning = c(50,75),
        danger = c(75,100)
      )
    )
  })
  
  # Forecast & Alert: Recommendation
  output$risk_recommendation <- renderPrint({
    pid <- as.numeric(input$patient_id)
    risk_prob <- model_data$RF_Prob[pid]
    
    if (risk_prob > 0.75) {
      rec <- "High Risk: Recommend psychiatric evaluation and urgent referral."
    } else if (risk_prob > 0.50) {
      rec <- "Moderate Risk: Monitor symptoms and schedule follow-up."
    } else {
      rec <- "Low Risk: Continue routine observation."
    }
    rec
  })
  
  
  output$risk_summary <- renderPrint({
    pid <- as.numeric(input$patient_id)
    paste0("RF Probability: ", round(model_data$RF_Prob[pid], 3),
           " | Risk: ", model_data$Risk_Category[pid])
  })
  
  output$roc_plot <- renderPlot({
    plot(rf_roc, col = "blue", main = "XGboost ROC Curve")
    abline(a=0,b=1,lty=2,col="gray")
  })
  
  # Feature Importance
  output$feature_importance_plot <- renderPlot({
    if ("randomForest" %in% class(rf_model)) {
      rf_imp <- as.data.frame(importance(rf_model))
      rf_imp$Feature <- rownames(rf_imp)
      rf_imp <- rf_imp %>% arrange(desc(MeanDecreaseGini)) %>% head(20)
      ggplot(rf_imp, aes(x = reorder(Feature, MeanDecreaseGini), y = MeanDecreaseGini)) +
        geom_bar(stat='identity', fill='steelblue') +
        coord_flip() +
        theme_minimal() +
        labs(title="Top 12 XGboost Feature Importances", x="", y="Importance")
    } else {
      rf_imp <- varImp(rf_model)$importance
      # Handle models without "Overall" column
      if (!"Overall" %in% colnames(rf_imp)) {
        rf_imp$Overall <- rowMeans(rf_imp)
      }
      rf_imp$Feature <- rownames(rf_imp)
      rf_imp <- rf_imp %>% arrange(desc(Overall)) %>% head(20)
      ggplot(rf_imp, aes(x = reorder(Feature, Overall), y = Overall)) +
        geom_bar(stat='identity', fill='steelblue') +
        coord_flip() +
        theme_minimal() +
        labs(title="Top 12 XGboost Feature Importances", x="", y="Importance")
    }
  })
}
