#EEG Signal Preprocessing
```{r}
fs <- 256  # Sampling frequency in Hz
low_cut <- 1
high_cut <- 45
sample_file <- norm_files[1]
raw_signal <- read_eeg_file(sample_file)$V1

bf <- butter(4, c(low_cut, high_cut)/(fs/2), type = "pass")
filtered_signal <- filtfilt(bf, raw_signal)
wt <- dwt(filtered_signal, filter = "haar", n.levels = 4)
wt@W <- lapply(wt@W, function(x) ifelse(abs(x) < 0.2, 0, x))
denoised_signal <- idwt(wt)

# Plot: Raw vs Filtered vs Denoised
plot_df <- data.frame(
  Time = 1:length(raw_signal) / fs,
  Raw = raw_signal,
  Filtered = filtered_signal,
  Denoised = denoised_signal
)

ggplot(plot_df[1:1000,], aes(x=Time)) +
  geom_line(aes(y=Raw, color="Raw")) +
  geom_line(aes(y=Filtered, color="Filtered")) +
  geom_line(aes(y=Denoised, color="Denoised")) +
  labs(title="EEG Signal: Raw vs Filtered vs Denoised",
       x="Time (s)", y="Amplitude (µV)") +
  scale_color_manual(values=c("Raw"="red", "Filtered"="blue", "Denoised"="green")) +
  theme_minimal()

```

