#Model Training
```{r}
set.seed(123)
train_index <- createDataPartition(model_data$Label, p = 0.8, list = FALSE)
train_data <- model_data[train_index, ]
test_data <- model_data[-train_index, ]

ctrl <- trainControl(
  method = "cv",
  number = 5,
  summaryFunction = twoClassSummary,
  classProbs = TRUE,
  savePredictions = TRUE
)

# Train the models
rf_model <- train(Label ~ ., data = train_data, method = "rf", trControl = ctrl,
                  importance = TRUE, metric = "ROC")
svm_model <- train(Label ~ ., data = train_data, method = "svmRadial", trControl = ctrl,
                   preProcess = c("center", "scale"), metric = "ROC")
glm_model <- train(Label ~ ., data = train_data, method = "glm", family = "binomial",
                   trControl = ctrl, metric = "ROC")
dt_model <- train(Label ~ ., data = train_data, method = "rpart", trControl = ctrl,
                  metric = "ROC")
xgb_model <- train(Label ~ ., data = train_data, method = "xgbTree", trControl = ctrl,
                   metric = "ROC")
```
