get_metrics <- function(cm, probs, labels) {
  acc <- cm$overall["Accuracy"]
  sens <- cm$byClass["Sensitivity"]
  spec <- cm$byClass["Specificity"]
  prec <- cm$byClass["Pos Pred Value"]
  rec  <- cm$byClass["Sensitivity"]
  f1   <- 2 * (prec * rec) / (prec + rec)
  auc  <- as.numeric(roc(labels, probs, levels = c("Healthy", "Schizophrenia"))$auc)
  data.frame(Accuracy=acc, Precision=prec, Recall=rec, F1=f1, AUC=auc)
}

metrics_df <- rbind(
  RandomForest = get_metrics(rf_cm, rf_prob, test_data$Label),
  SVM          = get_metrics(svm_cm, svm_prob, test_data$Label),
  LogisticReg  = get_metrics(glm_cm, glm_prob, test_data$Label),
  DecisionTree = get_metrics(dt_cm, dt_prob, test_data$Label),
  XGBoost      = get_metrics(xgb_cm, xgb_prob, test_data$Label)
)

