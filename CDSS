#Frequency-Domain Features
```{r}
compute_band_power <- function(epoch, fs) {
  fft_vals <- fft(epoch)
  power_spectrum <- (Mod(fft_vals)^2) / length(epoch)
  freqs <- seq(0, fs - fs/length(epoch), length.out = length(epoch))
  half <- 1:(length(epoch)/2)
  power_spectrum <- power_spectrum[half]
  freqs <- freqs[half]
  c(
    Delta = mean(power_spectrum[freqs >= 1  & freqs < 4]),
    Theta = mean(power_spectrum[freqs >= 4  & freqs < 8]),
    Alpha = mean(power_spectrum[freqs >= 8  & freqs < 13]),
    Beta  = mean(power_spectrum[freqs >= 13 & freqs < 30])
  )
}

freq_features <- as.data.frame(t(apply(epochs_norm, 1, compute_band_power, fs=fs)))

```

