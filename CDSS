# 2.4 Missing Data Handling
```{r}
set.seed(123)
signal_with_na <- denoised_signal
signal_with_na[sample(1:length(signal_with_na), 200)] <- NA

signal_interp <- na.approx(signal_with_na, na.rm = FALSE)

# Identify corrupted windows (>20% NA)
window_size <- samples_per_epoch
corrupt_idx <- sapply(
  seq(1, length(signal_with_na), by = window_size),
  function(i) {
    window <- signal_with_na[i:min(i+window_size-1, length(signal_with_na))]
    mean(is.na(window)) > 0.2
  }
)

cat("Number of corrupted windows removed:", sum(corrupt_idx), "\n")

```
