#Helper Function to Read Files Csv, npy, eea, it dectect the file type and load them

```{r}
read_eeg_file <- function(file_path) {
  ext <- tools::file_ext(file_path)
  
  if (ext == "csv") {
    return(read.csv(file_path, header = TRUE))
    
  } else if (ext == "npy") {
    np <- reticulate::import("numpy", convert = TRUE)
    return(as.data.frame(np$load(file_path)))
    
  } else if (ext == "eea") {
    df <- tryCatch({
      first_lines <- readLines(file_path, n = 5)
      if (any(grepl(",", first_lines))) {
        read.csv(file_path, header = FALSE)
      } else if (any(grepl("\t", first_lines))) {
        read.table(file_path, header = FALSE, sep = "\t", fill = TRUE)
      } else {
        read.table(file_path, header = FALSE, sep = "", fill = TRUE)
      }
    }, error = function(e) {
      stop(paste("Could not read .eea file:", file_path))
    })
    return(df)
    
  } else {
    stop(paste("Unsupported file format:", ext))
  }
}
```


